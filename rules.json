{
  "rules": [
    { "name": "AWS Access Key ID", "pattern": "\\b(AKIA|A3T|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}\\b" },
    { "name": "Google Cloud API Key", "pattern": "\\bAIza[0-9A-Za-z-_]{35}\\b" },
    { "name": "Google OAuth 2.0 Refresh Token", "pattern": "1//0[a-zA-Z0-9_-]{50,}" },
    { "name": "GitHub PAT (Classic)", "pattern": "ghp_[a-zA-Z0-9]{36}" },
    { "name": "GitHub PAT (Fine-Grained)", "pattern": "github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}" },
    { "name": "GitHub OAuth Access Token", "pattern": "gho_[a-zA-Z0-9]{36}" },
    { "name": "GitLab PAT", "pattern": "glpat-[a-zA-Z0-9\\-]{20}" },
    { "name": "Discord Bot Token", "pattern": "[\\w-]{24}\\.[\\w-]{6}\\.[\\w-]{27}" },
    { "name": "Slack Bot Token", "pattern": "xoxb-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24}" },
    { "name": "Slack User Token", "pattern": "xoxp-[0-9]{10,13}-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{32}" },
    { "name": "Slack Webhook", "pattern": "https://hooks\\.slack\\.com/services/T[a-zA-Z0-9_]{8}/B[a-zA-Z0-9_]{8}/[a-zA-Z0-9_]{24}" },
    { "name": "Telegram Bot Token", "pattern": "[0-9]{9,}:[a-zA-Z0-9_-]{35}" },
    { "name": "Stripe Standard Key", "pattern": "sk_live_[0-9a-zA-Z]{24}" },
    { "name": "Stripe Restricted Key", "pattern": "rk_live_[0-9a-zA-Z]{24}" },
    { "name": "Square Access Token", "pattern": "sq0atp-[0-9A-Za-z\\-_]{22}" },
    { "name": "Square OAuth Secret", "pattern": "sq0csp-[0-9A-Za-z\\-_]{43}" },
    { "name": "OpenAI API Key (Classic)", "pattern": "sk-[a-zA-Z0-9]{48}" },
    { "name": "OpenAI API Key (Project)", "pattern": "sk-proj-[a-zA-Z0-9_-]{20,}" },
    { "name": "Anthropic API Key", "pattern": "sk-ant-[a-zA-Z0-9_-]{80,}" },
    { "name": "HuggingFace Access Token", "pattern": "hf_[a-zA-Z0-9]{34}" },
    { "name": "Cohere API Key", "pattern": "[a-zA-Z0-9]{40}" },
    { "name": "NPM Access Token", "pattern": "npm_[a-zA-Z0-9]{36}" },
    { "name": "PyPI API Token", "pattern": "pypi-AgEIcHlwaS5vcmc[A-Za-z0-9\\-_]{50,}" },
    { "name": "Heroku API Key", "pattern": "[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}" },
    { "name": "DigitalOcean PAT", "pattern": "dop_v1_[0-9a-fA-F]{64}" },
    { "name": "Twilio API Key", "pattern": "SK[0-9a-fA-F]{32}" },
    { "name": "SendGrid API Key", "pattern": "SG\\.[a-zA-Z0-9_-]{22}\\.[a-zA-Z0-9_-]{43}" },
    { "name": "Mailchimp API Key", "pattern": "[0-9a-f]{32}-us[0-9]{1,2}" },
    { "name": "Mailgun API Key", "pattern": "key-[0-9a-zA-Z]{32}" },
    { "name": "Supabase API Key", "pattern": "sbp_[a-zA-Z0-9]{40}" },
    { "name": "Firebase Cloud Messaging", "pattern": "AAAA[a-zA-Z0-9_-]{38}:[a-zA-Z0-9_-]{140}" },
    { "name": "Shopify Access Token", "pattern": "shpat_[a-fA-F0-9]{32}" },
    { "name": "Shopify Custom App Token", "pattern": "shpca_[a-fA-F0-9]{32}" },
    { "name": "Shopify Shared Secret", "pattern": "shpss_[a-fA-F0-9]{32}" },
    { "name": "Docker Hub Token", "pattern": "dckr_pat_[a-zA-Z0-9_-]{20,}" },
    { "name": "Bitbucket App Password", "pattern": "ATBB[a-zA-Z0-9_-]{40,}" },
    { "name": "HashiCorp Vault Token", "pattern": "hvs\\.[a-zA-Z0-9_-]{90,}" },
    { "name": "RSA Private Key", "pattern": "-----BEGIN RSA PRIVATE KEY-----" },
    { "name": "SSH Private Key", "pattern": "-----BEGIN OPENSSH PRIVATE KEY-----" },
    { "name": "PGP Private Key", "pattern": "-----BEGIN PGP PRIVATE KEY BLOCK-----" },
    { "name": "EC Private Key", "pattern": "-----BEGIN EC PRIVATE KEY-----" }
  ]
}
